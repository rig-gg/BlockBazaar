# BlockBazaar Environment Variables

# Backend (copy to backend/src/main/resources/application.properties or use env vars)

# Database (Supabase PostgreSQL)
DB_URL=jdbc:postgresql://your-project-ref.supabase.co:5432/postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-database-password

# JWT
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
JWT_EXPIRATION=86400000

# External API (instructor-assigned, TBD)
EXTERNAL_API_KEY=

# Frontend (copy to frontend/.env)
REACT_APP_API_URL=http://localhost:8080
